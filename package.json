{
  "name": "depaneuria-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "eslint .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "dev:web": "turbo run dev --filter=\"./apps/web-*\"",
    "dev:api": "turbo run dev --filter=\"./apps/api\" --filter=\"./apps/phone-gateway\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:migrate": "tsx scripts/dev/migrate.ts",
    "db:seed": "tsx scripts/dev/seed-demo.ts",
    "db:clear": "tsx scripts/dev/clear-demo.ts",
    "verify:local": "pnpm run lint && pnpm run typecheck && pnpm run build"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "latest",
    "prettier": "^3.0.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "tsx": "^4.0.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
