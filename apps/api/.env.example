# ============================================================
# .env.example — apps/api
# ============================================================
# Copier ce fichier en .env et renseigner les valeurs.
# Ne jamais commiter .env
# ============================================================

# Environnement
NODE_ENV=development

# Port du serveur API
PORT=3001

# URL de la base de données SQLite (Prisma)
# Chemin relatif au dossier prisma/ de apps/api
DATABASE_URL="file:./dev.db"
