{
  "name": "@depaneuria/api",
  "version": "0.1.0",
  "private": true,
  "description": "API REST depaneurIA — Express + Prisma + SQLite",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@depaneuria/types": "workspace:*",
    "@prisma/client": "^6.4.1",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.6.0"
  }
}
