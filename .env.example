# .env.example - Modèle de variables d'environnement
# NE JAMAIS COMMITTER de vraies clés secrètes ici.

# General
NODE_ENV=development
PORT=3000

# API Urls
NEXT_PUBLIC_API_URL=http://localhost:3000

